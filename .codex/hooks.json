{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project \"$(git rev-parse --show-toplevel)\" python \"$(git rev-parse --show-toplevel)/hooks/session-start.py\"",
            "timeout": 15,
            "statusMessage": "Loading memory context"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project \"$(git rev-parse --show-toplevel)\" python \"$(git rev-parse --show-toplevel)/hooks/stop.py\"",
            "timeout": 20,
            "statusMessage": "Flushing conversation memory"
          }
        ]
      }
    ]
  }
}
